<script>
    $(document).ready(function () {
        // Variable pour suivre le nombre de soumissions
        var submissionsCount = 0;
        // Variable pour suivre si l'alerte pour le nombre minimum a déjà été affichée
        var minAlertShown = false;

        $('#ObjVForm').submit(function (event) {
            // Empêcher le comportement par défaut du formulaire
            event.preventDefault();

            // Récupérer les données du formulaire
            var formData = $(this).serialize();

            // Vérifier le nombre de soumissions
            if (submissionsCount < 6) {
                // Effectuer une requête AJAX pour soumettre le formulaire
                $.ajax({
                    url: $(this).attr('action'),
                    type: $(this).attr('method'),
                    data: formData,
                    success: function (data) {
                        // Actualiser le contenu de la stepPage2
                        $('#stepPage2').html($(data).find('#stepPage2').html());

                        // Masquer la modal après la soumission réussie
                        $('#myModal3').modal('hide');

                        // Supprimer le backdrop après la fermeture de la modal
                        $('.modal-backdrop').remove();

                        // Incrémenter le nombre de soumissions
                        submissionsCount++;

                        // Vérifier si le nombre maximum de soumissions est atteint après l'incrémentation
                        if (submissionsCount >= 6) {
                            // Désactiver le bouton d'ouverture de modal
                            $('#myModal3Btn').prop('disabled', true);
                            alert("Vous avez atteint le nombre maximum de soumissions.");
                        } else if (submissionsCount === 3 && !minAlertShown) {
                            // Afficher l'alerte pour le nombre minimum uniquement à la 3ème soumission si elle n'a pas déjà été affichée
                            minAlertShown = true;
                            alert("Vous avez atteint le nombre minimum de soumissions. Vous pouvez continuer à remplir le formulaire.");
                        }
                    },
                    error: function (xhr, status, error) {
                        // Gérer les erreurs en conséquence
                        console.error(error);
                    }
                });

                // Si c'est la 3ème soumission, afficher les données saisies dans le tableau
                if (submissionsCount === 2) {
                    // Insérer les données dans le tableau
                    $('#objectifsTable').append('<tr>' +
                        '<td>' + formData.get('ObjectifsPrincipeauxSmart') + '</td>' +
                        '<td>' + formData.get('indicateur') + '</td>' +
                        '<td>' + formData.get('ARealiserEnT1__T4') + '</td>' +
                        '</tr>');
                }
            } else {
                // Si le nombre de soumissions est supérieur ou égal à 6, empêcher la soumission
                alert("Vous avez atteint le nombre maximum de soumissions.");
            }
        });
    });
</script>


