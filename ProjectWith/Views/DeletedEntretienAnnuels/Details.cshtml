<script>
    // Compteur de soumissions
    var submissionCount = 0;

    // Nombre minimal de soumissions autorisées
    var minSubmissions = 3;

    // Nombre maximal de soumissions autorisées
    var maxSubmissions = 6;

    // Sélection du formulaire
    var form = document.getElementById('ObjVForm');

    // Ajout d'un écouteur d'événements pour la soumission du formulaire
    form.addEventListener('submit', function (event) {
        // Incrémenter le compteur de soumissions
        submissionCount++;

        // Vérifier si le nombre maximal de soumissions est atteint
        if (submissionCount > maxSubmissions) {
            // Empêcher la soumission du formulaire
            event.preventDefault();
            // Afficher un message pour informer l'utilisateur
            alert('Vous ne pouvez ajouter que jusqu\'à 6 objectifs à venir.');
        } else if (submissionCount >= minSubmissions) {
            // Afficher un message pour informer l'utilisateur
            alert('Vous avez atteint le nombre minimal d\'objectifs à ajouter.');
        }
    });
</script>



