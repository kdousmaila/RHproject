                            event.preventDefault(); // Prevent default link behavior

                            var id = $(this).data('id');

                            // Send AJAX request to delete the item
                            $.ajax({
                                url: '/ObjSpecifiques/Delete/' + id,
                                type: 'POST',
                                data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                                success: function () {
                                    // Remove the row from the table upon successful deletion
                                    $('#objSpecifiqueTable tr[data-id="' + id + '"]').remove();
                                },
                                error: function (xhr, status, error) {
                                    console.error(error);
                                }
                            });
                        });

                    // Append delete link to table row
                    var newRowHtml = $('<tr></tr>')
                        .append('<td>' + data.ObjectifSpecifique + '</td>')
                        .append('<td>' + data.Synthese + '</td>')
                        .append($('<td></td>').append(deleteLink));

                    // Append new row to table
                    $('#objSpecifiqueTable').append(newRowHtml);
                },
                error: function (xhr, status, error) {
                    console.error(error);
                }
            });
        });
    });
</script>

















