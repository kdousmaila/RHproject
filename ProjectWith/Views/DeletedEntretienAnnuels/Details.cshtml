<script>
    var currentStep = 1;
    var stepsNum = 5;

    // show default page
    document.getElementById("stepPage" + currentStep).style.display = "block";
    document.getElementById("stepLable" + currentStep).classList.add("activeStep");

    // change step from current active step to a new active (next or previous)
    function changeStep(active, newActive) {
        // get active step page and hide it
        document.getElementById("stepPage" + active).style.display = "none";

        // show new step page
        document.getElementById("stepPage" + newActive).style.display = "block";

        // get active step label and remove class active
        var activeStepL = document.querySelector(".activeStep");
        activeStepL.classList.remove("activeStep");

        // get new active step label, add class active
        var newActiveStepL = document.getElementById("stepLable" + newActive);
        newActiveStepL.classList.add("activeStep");

        // update progress bar
        var p = (100 / (stepsNum - 1)) * (newActive - 1);
        document.getElementById("completedProgress").style.width = p + "%";

        // if user moves to next step, add class completed to previous
        if (active < newActive) {
            activeStepL.classList.add("completedStep");
            activeStepL.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" style="font-size:40px" fill="currentColor" class="bi bi-check" viewBox="0 0 16 16">' + '<path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/>' + '</svg>';
        }

        // avoid overlap, remove class completed from new active
        if (newActiveStepL.classList.contains("completedStep")) {
            newActiveStepL.classList.remove("completedStep");
            newActiveStepL.innerHTML = newActive;
        }

        // Show or hide submit button based on the current step
        if (newActive === stepsNum) {
            // Remove the next button
            document.getElementById("next").style.display = "none";

            // Create a submit button if it doesn't exist
            var submitButton = document.getElementById("send");
            if (!submitButton) {
               // submitButton = document.createElement("button");
                submitButton.innerHTML = "Submit";
                submitButton.type = "submit";
                submitButton.id = "send"; // Set the ID to "send"
                //submitButton.onclick = function (event) {
                //    event.preventDefault();
                //    document.getElementById("entretienForm").submit();
                //};

                // Append the submit button to the navigation
                var nav = document.getElementById("navigation");
                nav.appendChild(submitButton);
            }
        } else {
            // Change the button text and ID back to default
            document.getElementById("next").style.display = "inline"; // Make sure the "Next" button is visible
            document.getElementById("next").innerHTML = "&gt;";
            document.getElementById("next").id = "next"; // Change ID back to "next"

            // Remove the submit button if it exists
            var submitButton = document.getElementById("send");
            if (submitButton) {
                submitButton.parentNode.removeChild(submitButton); // Remove the "Submit" button if present
            }
        }
    }

    // Add event listeners to step labels in the progress bar
    document.querySelectorAll("#progressbarContainer ul li").forEach(function (stepLabel) {
        stepLabel.addEventListener("click", function () {
            // Get the step number from the clicked label
            var newStep = parseInt(stepLabel.innerHTML);

            // Change the step
            if (newStep !== currentStep) {
                changeStep(currentStep, newStep);
                currentStep = newStep;

                // Update visibility of previous and next buttons based on the current step
                if (currentStep === 1) {
                    document.getElementById("prev").style.visibility = "hidden";
                } else {
                    document.getElementById("prev").style.visibility = "visible";
                }

                if (currentStep === stepsNum) {
                    document.getElementById("next").style.display = "none";
                } else {
                    document.getElementById("next").style.display = "inline";
                }
            }
        });
    });

    document.getElementById("next").addEventListener("click", next);
    document.getElementById("prev").addEventListener("click", prev);


    function next(event) {
        // Prevent the default form submission behavior
        event.preventDefault();

        window.scrollTo(0, 0);

        // Check if it's the last step
        if (currentStep >= stepsNum) {
            // Submit the form
            document.getElementById("entretienForm").submit();
        } else {
            // Move to the next step
            changeStep(currentStep, currentStep + 1);
            currentStep++;
            document.getElementById("prev").style.visibility = "visible";

            // Check if it's the last step
            if (currentStep === stepsNum) {
                // Remove the next button
                var nextButton = document.getElementById("next");
                nextButton.style.display = "none";

                // Create a submit button if it doesn't exist
                var submitButton = document.getElementById("send");
                if (!submitButton) {
                    submitButton = document.createElement("button");
                    submitButton.innerHTML = "Submit";
                    submitButton.type = "submit";
                    submitButton.id = "send"; // Set the ID to "send"
                    submitButton.onclick = function (event) {
                        event.preventDefault();
                        document.getElementById("entretienForm").submit();
                    };

                    // Append the submit button to the desired nav element
                    var navElement = document.getElementById("navigation"); // Change this to your desired nav element ID
                    navElement.appendChild(submitButton);

                    // Style the submit button to match the other buttons in the nav element
                    submitButton.classList.add("btn", "btn-primary", "ml-2");
                }
            } else {
                // Change the button text and ID back to default
                document.getElementById("next").innerHTML = "&gt;";
                document.getElementById("next").id = "next"; // Change ID back to "next"
            }
        }
    }











    function prev(event) {
        event.preventDefault(); // Prevent default form submission behavior
        window.scrollTo(0, 0);

        // Make sure you're not going back beyond the first step
        if (currentStep >= 2) {
            // Move to the previous step
            changeStep(currentStep, currentStep - 1);
            currentStep--;

            // Hide the "Previous" button if it's the first step
            if (currentStep < 2) {
                document.getElementById("prev").style.visibility = "hidden";
            }

            // Check if you're on the last step
            if (currentStep === stepsNum) {
                // Remove the submit button and restore the "Next" button
                var submitButton = document.getElementById("send");
                if (submitButton) {
                    submitButton.parentNode.removeChild(submitButton); // Remove the "Submit" button if present
                }
                document.getElementById("next").style.display = "inline"; // Make sure the "Next" button is visible
            }
        }

        // If not on the last step, ensure the submit button is hidden and the next button is visible
        if (currentStep !== stepsNum) {
            var submitButton = document.getElementById("send");
            if (submitButton) {
                submitButton.parentNode.removeChild(submitButton); // Remove the "Submit" button if present
            }
            document.getElementById("next").style.display = "inline"; // Make sure the "Next" button is visible
        }
    }
</script>



