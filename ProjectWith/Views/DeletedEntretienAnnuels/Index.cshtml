@model IEnumerable<ProjectWith.Models.DeletedEntretienAnnuel>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}



<style>
    /* Style de base pour les tableaux */
    table tr {
        border-bottom: 1px solid #ddd; /* Style of the separation line */
    }

    /* CSS style for left and right borders */
    table {
        border-collapse: collapse; /* Collapse the borders */
        border: 1px solid #ddd; /* Table border */
        width: 100%; /* Set table width to 100% */
    }

        /* CSS style for column separation */
        table th,
        table td {
            border-right: 1px solid #ddd; /* Style of the separation line */
            padding: 8px; /* Add padding for better appearance */
            color: #333; /* Darker text color */
        }

    /* Style pour une colonne spécifique */
    .large-column {
        width: 100%; /* Largeur de la deuxième colonne */
    }

    /* Styles pour les en-têtes de tableau */
    .header {
        color: #fff;
        padding: 10px;
    }

    .header-content {
        margin: 0 auto;
        max-width: 1200px;
    }

    .action-buttons {
        display: flex;
        justify-content: center; /* Alignement horizontal au centre */
    }

    .text-black {
        color: #000000; /* Couleur noire */
    }
</style>
<style>
    /* Ajouter une marge en haut et en bas de la pagination */
    .pagination-wrapper {
        margin-top: 20px;
        margin-bottom: 20px;
    }
</style>
<h5 style="color: #c21c1c; font-size: 24px; font-weight: bold; margin-top: 20px;">Historique</h5>
@using (Html.BeginForm("Index", "DeletedEntretienAnnuels", FormMethod.Get))
{

    <div class="row mb-5">
        <div class="col-4" style=" margin-top: 30px;">
            <form class="d-none d-sm-inline-block form-inline mr-auto ml-md-3 my-2 my-md-0 mw-100 navbar-search">
                <div class="input-group">
                    <input type="text" name="searchLetter" class="form-control input-primary text-black small" placeholder="Rechercher..."
                           aria-label="Search" aria-describedby="basic-addon2">
                    <div class="input-group-append">
                        <button class="btn btn-primary" type="submit" value="Search">
                            <i class="fas fa-search fa-sm"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>




}
@if (string.IsNullOrEmpty(ViewBag.Matricule) && (@ProjectWith.Models.ath_windows.CurrentUser.getRole() == "RH" || @ProjectWith.Models.ath_windows.CurrentUser.getRole() == "DS"))
{
    <table>
        <thead>
            <tr>
                <th style="text-align: center;">Matricule</th>
                <th style="text-align: center;">Nom</th>
                <th style="text-align: center;">Prénom</th>
                <th style="text-align: center;">Fonction</th>
                <th style="text-align: center;">Service</th>
                <th style="text-align: center;">Note</th>
                <th style="text-align: center;">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>

                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Matricule)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Nom)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Prenom)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.LibelleFonction)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Service)</td>
                    <td style="text-align: center;">@Html.DisplayFor(modelItem => item.Note)</td>

                    <td style="text-align: center;">
                        <div class="btn-group">
                            <a href="@Url.Action("Details", new { id = item.id })" class="btn btn-info me-2" title="Détails entretien" style="text-decoration:none;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye" viewBox="0 0 16 16">
                                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                    <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                                </svg>
                            </a>

                            @*@if (ProjectWith.Models.ath_windows.CurrentUser.getRole() == "RH" || ProjectWith.Models.ath_windows.CurrentUser.getRole() == "DS")
                                {
                                    <form id="deleteForm-@item.id" action="@Url.Action("Delete", "DeletedEntretienAnnuels", new { id = item.id })" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-danger delete-btn" data-id="@item.id" title="Supprimer entretien">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                                            </svg>
                                        </button>
                                    </form>
                                }*@
                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
    <div class="pagination-wrapper">
        <div class="row justify-content-center">
            <div class="col-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item">
                        <a class="page-link" href="/DeletedEntretienAnnuels/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left-short" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5" />
                            </svg>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.NoOfPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.PageNo ? "active" : "")">
                            <a class="page-link" href="/DeletedEntretienAnnuels/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=@i">@i</a>
                        </li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="/DeletedEntretienAnnuels/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=@ViewBag.NoOfPages"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-short" viewBox="0 0 16 16">
    <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8" />
</svg></a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <script>
        // JavaScript code to handle delete button click
        document.addEventListener('DOMContentLoaded', function () {
            // Select all delete buttons
            var deleteButtons = document.querySelectorAll('.delete-btn');

            // Add click event listener to each delete button
            deleteButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var confirmDelete = confirm("Êtes-vous sûr de vouloir supprimer cet entretien ?");
                    if (confirmDelete) {
                        // Get the corresponding form
                        var form = document.getElementById('deleteForm-' + btn.getAttribute('data-id'));
                        // Submit the form
                        form.submit();
                    }
                });
            });
        });
    </script>
}
else
{
    <script>
    window.location.href = '@Url.Action("Unauthorized", "Error")';
    </script>
}

