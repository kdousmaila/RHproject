@model IEnumerable<ProjectWith.Models.permission>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<style>
    /* CSS style for row separation */
    table tr {
        border-bottom: 1px solid #ddd; /* Style of the separation line */
    }

    /* CSS style for left and right borders */
    table {
        border-collapse: collapse; /* Collapse the borders */
        border: 1px solid #ddd; /* Table border */
        width: 100%; /* Set table width to 100% */
    }

        /* CSS style for column separation */
        table th,
        table td {
            border-right: 1px solid #ddd; /* Style of the separation line */
            padding: 8px; /* Add padding for better appearance */
            color: #333; /* Darker text color */
            text-align: center; /* Center align content */
        }
</style>
<h5 style=" color: #c21c1c; font-size: 24px; font-weight: bold; margin-top: 20px;">Liste Des Rôles</h5>


@using (Html.BeginForm("Index", "Permissions", FormMethod.Get))
{

    <div class="row mb-5" style=" margin-top: 30px;">
        <div class="col-4">
            <form class="d-none d-sm-inline-block form-inline mr-auto ml-md-3 my-2 my-md-0 mw-100 navbar-search">
                <div class="input-group">
                    <input type="text" name="searchLetter" class="form-control input-primary text-black small" placeholder="Search for..."
                           aria-label="Search" aria-describedby="basic-addon2">
                    <div class="input-group-append">
                        <button class="btn btn-primary" type="submit" value="Search">
                            <i class="fas fa-search fa-sm"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>




}
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Employee.Matricule)</th>
            <th>@Html.DisplayNameFor(model => model.Employee.Nom)</th>
            <th>@Html.DisplayNameFor(model => model.Employee.Prenom)</th>

            <th>Rôle</th>
            <th>Profile</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Employee.Matricule)</td>
                <td>@Html.DisplayFor(modelItem => item.Employee.Nom)</td>
                <td>@Html.DisplayFor(modelItem => item.Employee.Prenom)</td>
                <td>@Html.DisplayFor(modelItem => item.Role.libelle)</td>
                <td>
                    <a href="@Url.Action("RedirectToFicheFonction", "permissions", new { id = item.id })" class="btn btn-info me-2" title="Détails employe" style="text-decoration:none">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                        </svg>
                    </a>
                </td>
                <td class="text-end">
                    <div>
                        <!-- Boutons d'action -->
                        <a href="@Url.Action("Edit", new { id = item.id})" class="btn btn-success me-2" title="Edit employe">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                            </svg>
                        </a>




                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
<div class="row justify-content-center">
    <div class="col">
        <ul class="pagination justify-content-center">
            <li class="page-item">
                <a class="page-link" href="/Permissions/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left-short" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5" />
                    </svg>
                </a>
            </li>
            @for (int i = 1; i <= ViewBag.NoOfPages; i++)
            {
                <li class="page-item @(i == ViewBag.PageNo ? "active" : "")">
                    <a class="page-link" href="/Permissions/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=@i">@i</a>
                </li>
            }
            <li class="page-item">
                <a class="page-link" href="/Permissions/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=@ViewBag.NoOfPages">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-short" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8" />
                    </svg>
                </a>
            </li>
        </ul>
    </div>
</div>
<script>
    // Attacher un gestionnaire d'événements pour déclencher l'ouverture du menu
    document.getElementById("dropdownMenuLink").addEventListener("click", function (event) {
        event.preventDefault(); // Empêcher le comportement par défaut du lien
        var dropdownMenu = document.querySelector("#dropdownMenuLink + ul");
        dropdownMenu.classList.toggle("show"); // Afficher ou masquer le menu déroulant
    });
</script>




