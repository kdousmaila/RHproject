
@model ProjectWith.Models.ObjectifsAVenir

<tr data-id="@Model.id">
    <td>@Model.ObjectifsPrincipeauxSmart</td>
    <td>@Model.indicateur</td>
    <td>@Model.ARealiserEnT1__T4</td>
    <td>
     
            @Html.ActionLink("Delete", "Delete", "ObjectifsAVenirs", new { id = Model.id }, new { @class = "delete-link", data_id = Model.id })

            @Html.AntiForgeryToken() <!-- Add anti-forgery token here -->

       
    </td>
</tr>


