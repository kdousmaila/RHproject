        <script>
    $("#Send").on("click", function () {
        var id = $("#FicheFonctions_id").val();
        var nom = $("#FicheFonctions_nom").val();
        var prenom = $("#FicheFonctions_prenom").val();
        var email = $("#FicheFonctions_email").val();
        var ville = $("#FicheFonctions_ville").val();
        var etatCivil = $("#FicheFonctions_etatCivil").val();
        var numRib = $("#FicheFonctions_numRib").val();
        var numero = $("#FicheFonctions_numero").val();
        var dateNaissance = $("#FicheFonctions_dateNaissance").val();
        var numCin = $("#FicheFonctions_numCin").val();
        var poste = $("#FicheFonctions_poste").val();
        var dateRecrutement = $("#FicheFonctions_dateRecrutement").val();
        var Matricule = $("#FicheFonctions_matricule").val();

        // Create FormData object
        var formData = new FormData();
        formData.append("id", id);
        formData.append("nom", nom);
        formData.append("prenom", prenom);
        formData.append("email", email);
        formData.append("ville", ville);
        formData.append("etatCivil", etatCivil);
        formData.append("numRib", numRib);
        formData.append("numero", numero);
        formData.append("dateNaissance", dateNaissance);
        formData.append("numCin", numCin);
        formData.append("poste", poste);
        formData.append("dateRecrutement", dateRecrutement);
        formData.append("Matricule", Matricule);

        // Append image file to FormData if it exists
        var imageFile = $("#imageFile").prop("files")[0];
        if (imageFile) {
            formData.append("imageFile", imageFile);
        }

        $.ajax({
            type: "POST",
            url: "@Url.Action("Edit", "DeletedFicheFonctions")",
            data: formData, // Use formData instead of data
            contentType: false, // Set content type to false for FormData
            processData: false, // Set processData to false for FormData
            success: function (data) {
                console.log("Modifications enregistrées avec succès");
                window.location.reload();
                // Rediriger ou afficher un message de succès si nécessaire
            },
            error: function (xhr, status, error) {
                console.error("Erreur lors de la modification :", error);
                // Gérer les erreurs si nécessaire
            }
        });
    });
        </script>





        @section scripts {
            <script>
                $(document).ready(function () {
                    // Function to set min attribute of end date input based on start date input value
                    function setMinEndDate() {
                        var startDate = $('#dateDebut').val();
                        $('#dateFin').attr('min', startDate);
                    }

                    // Function to validate date input
                    function validateDates() {
                        var startDate = $('#dateDebut').val();
                        var endDate = $('#dateFin').val();
                        var currentDate = new Date().toISOString().split('T')[0]; // Get current date in 'yyyy-mm-dd' format

                        // Check if start date is in the future
                        if (startDate > currentDate) {
                            alert('La date de début ne peut pas être dans le futur.');
                            $('#dateDebut').val(''); // Clear the start date field
                            return false;
                        }

                        // Check if end date is before start date
                        if (startDate && endDate && endDate < startDate) {
                            alert('La date de fin doit être après la date de début.');
                            $('#dateFin').val('');
                            return false;
                        }
                        return true;
                    }

                    // Set min attribute of end date input when start date changes
                    $('#dateDebut').change(function () {
                        setMinEndDate();
                    });

                    // Validate dates on form submission
                    $('#formationForm').submit(function () {
                        return validateDates();
                    });


                });
            </script>


