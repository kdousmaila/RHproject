                        <script>
    function validateImage() {
        var allowedExtensions = /(\.png|\.jpg|\.jpeg)$/i;
        var fileInput = document.getElementById('imageFile');
        var errorDiv = document.getElementById('error-msg');

        if (!allowedExtensions.exec(fileInput.value)) {
            errorDiv.style.display = 'block';
            fileInput.value = '';
        } else {
            errorDiv.style.display = 'none';
        }
    }

    $(document).ready(function () {
        var initialInputValue = $('#FicheFonctions_numero').val();
        var inputModified = false;

        $('#FicheFonctions_numero').on('input', function () {
            inputModified = $(this).val() !== initialInputValue;
        });

        $('#FicheFonctions_numero').on('blur', function () {
            var numero = $(this).val();
            var regex = /^(?:\+216)?\d{8}$/;

            if (inputModified) {
                if (!regex.test(numero)) {
                    $('#numero-error').text('choisir un numéro de telephone valide.');
                    $("#Send").prop("disabled", true);
                } else {
                    $.ajax({
                        url: '@Url.Action("CheckNumero", "FicheFonctions")',
                        type: 'GET',
                        data: { numero: numero },
                        success: function (response) {
                            if (response.exists) {
                                $("#Send").prop("disabled", true);
                                $('#numero-error').text('Ce numéro de téléphone existe déjà.');
                            } else {
                                $("#Send").prop("disabled", false);
                                $('#numero-error').text('');
                            }
                        }
                    });
                }
            } else if (!numero) {
                $('#numero-error').text('Le champ ne peut pas être vide.');
                $("#Send").prop("disabled", true);
            } else {
                $("#Send").prop("disabled", false);
                $('#numero-error').text('');
            }
        });

        $("#Send").prop("disabled", false);
    });
                        </script>






