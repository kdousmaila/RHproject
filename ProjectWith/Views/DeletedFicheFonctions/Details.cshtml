            <script>
                $(document).ready(function () {
                    // Function to validate file types
                    function validateFileType(input, allowedTypes) {
                        var fileName = input.value;
                        var idxDot = fileName.lastIndexOf(".") + 1;
                        var extFile = fileName.substr(idxDot, fileName.length).toLowerCase();
                        if (allowedTypes.indexOf(extFile) == -1) {
                            alert("Choose a PDF, PNG, JPG, or JPEG file.");
                            input.value = "";
                        }
                    }

                    // Event listener for file input change
                    $(".form-control-file").change(function () {
                        var allowedTypes = ["pdf", "png", "jpg", "jpeg"];
                        validateFileType(this, allowedTypes);
                    });
                });
            </script>



