                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-windows rouge" viewBox="0 0 16 16">
                                            <path d="M6.555 1.375 0 2.237v5.45h6.555zM0 13.795l6.555.933V8.313H0zm7.278-5.4.026 6.378L16 16V8.395zM16 0 7.33 1.244v6.414H16z" />
                                        </svg>@Model.DeletedFicheFonctions.cmptWindows
                                    </div><br />
                                    <div class="icon-text">
                                        <div class="icon-text">
                                            <i class="fas fa-calendar mr-2 rouge"></i>
                                            <span id="dateRecrutement"></span>
                                        </div>

                                        <script>
    // Suppose that @Model.DeletedFicheFonctions.dateRecrutement contains the recruitment date in the format "yyyy-mm-dd"
    var dateRecrutement = "@Model.DeletedFicheFonctions.dateRecrutement"; // Get the recruitment date from your model

    // Convert the date string into a Date object
    var dateObjRecrutement = new Date(dateRecrutement);

    // Extract the day, month, and year
    var jourRecrutement = dateObjRecrutement.getDate();
    var moisRecrutement = dateObjRecrutement.getMonth() + 1; // Months start from 0, so add 1
    var anneeRecrutement = dateObjRecrutement.getFullYear();

    // Add leading zero to day and month if necessary
    if (jourRecrutement < 10) {
        jourRecrutement = '0' + jourRecrutement;
    }
    if (moisRecrutement < 10) {
        moisRecrutement = '0' + moisRecrutement;
    }

    // Format the date as dd/mm/yyyy
    var dateFormateeRecrutement = jourRecrutement + '/' + moisRecrutement + '/' + anneeRecrutement;

    // Update the content of the span element with id "dateRecrutement" with the formatted date
    document.getElementById("dateRecrutement").textContent = dateFormateeRecrutement;
                                        </script>

                                    </div><br />
                                    <div class="icon-text">
