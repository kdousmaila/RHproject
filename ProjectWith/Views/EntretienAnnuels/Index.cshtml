@model IEnumerable<ProjectWith.Models.EntretienAnnuel>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* CSS style for row separation */
    table tr {
        border-bottom: 1px solid #ddd; /* Style of the separation line */
    }

    /* CSS style for left and right borders */
    table {
        border-collapse: collapse; /* Collapse the borders */
        border: 1px solid #ddd; /* Table border */
        width: 100%; /* Set table width to 100% */
    }

        /* CSS style for column separation */
        table th,
        table td {
            border-right: 1px solid #ddd; /* Style of the separation line */
            padding: 8px; /* Add padding for better appearance */
            color: #333; /* Darker text color */
            text-align: center; /* Center align content */
        }

    .create-new-container {
        text-align: right;
    }

    .create-new-button {
        display: inline-block;
        padding: 6px 7px;
        font-size: 16px;
        color: #fff; /* Changement de la couleur du texte en blanc */
        background-color: #ba2d2d; /* Changement de la couleur de fond en rouge */
        border: none;
        border-radius: 6px;
        text-decoration: none;
    }

        .create-new-button:hover {
            background-color: #801f1f; /* Changement de la couleur de fond au survol */
        }

    .container-box {
        border: 0px solid #ddd;
        border-radius: 5px;
        background-color: #f8f9fa;
    }

    .action-buttons .btn {
        margin-right: 5px; /* Ajoute une marge à droite pour créer un espace entre les boutons */
    }
</style>
<h5 style=" color: #c21c1c; font-size: 24px; font-weight: bold; margin-top: 20px;">Liste Des Entretiens Annuels</h5>

<div class="row mb-5" style="margin-top: 30px;">

    <div class="col-8">

        @using (Html.BeginForm("Index", "EntretienAnnuels", FormMethod.Get, new { @class = "form-inline" }))
        {
            <div class="input-group">
                <input type="text" name="searchLetter" class="form-control input-primary text-black small" placeholder="Rechercher"
                       aria-label="Search" aria-describedby="basic-addon2">
                <div class="input-group-append">
                    <button class="btn btn-primary" type="submit" value="Search">
                        <i class="fas fa-search fa-sm"></i>
                    </button>
                </div>
            </div>
        }
    </div>
    @if (ViewBag.AccessGranted != null && (bool)ViewBag.AccessGranted)
    {
        <div class="col-4 text-right">
            <a href="@Url.Action("Create")" class="btn btn-secondary create-new-button">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus" viewBox="0 0 16 16">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4" />
                </svg>
                Ajouter
            </a>
        </div>}

</div>

@if (Model.Any())
{
    <div class="row justify-content-center ">
        <!-- Centering the content -->
        <div class="col-12">
            <!-- Adjust width as needed -->
            <table class="table">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Nom)</th>
                        <th>@Html.DisplayNameFor(model => model.Prenom)</th>
                        <th>Libellé fonction</th>
                        <th>@Html.DisplayNameFor(model => model.Service)</th>
                        <th>@Html.DisplayNameFor(model => model.DateEntretien)</th>
                        @if ((bool)(Session["AccessGranted"] ?? false))
                        {
                            <th class="text-end">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Nom)</td>
                            <td>@Html.DisplayFor(modelItem => item.Prenom)</td>
                            <td>@Html.DisplayFor(modelItem => item.LibelleFonction)</td>
                            <td>@Html.DisplayFor(modelItem => item.Service)</td>
                            <td style="text-align: center;">@item.DateEntretien.ToString("yyyy-MM-dd")</td>
                            @if ((bool)(Session["AccessGranted"] ?? false))
                            {
                                <td class="text-center">
                                    <div class="btn-group action-buttons" role="group" aria-label="Actions">
                                        <!-- Bouton Détails -->
                                        <a href="@Url.Action("Details", new { id = item.id })" class="btn btn-info me-2" title="Détails entretien" style="text-decoration: none; border-radius: 5px; ">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                                            </svg>
                                        </a>

                                        <!-- Bouton Supprimer -->
                                        @if (ProjectWith.Models.ath_windows.CurrentUser.getRole() == "RH" || ProjectWith.Models.ath_windows.CurrentUser.getRole() == "DS")
                                        {
                                            <form id="deleteForm-@item.id" action="@Url.Action("Delete", "EntretienAnnuels", new { id = item.id })" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="button" class="btn btn-danger delete-btn" data-id="@item.id" title="Supprimer entretien">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                                                    </svg>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>

                            }
                        </tr>
                    }
                </tbody>
            </table>
            <div class="row justify-content-center">
                <div class="col">
                    <ul class="pagination justify-content-center">
                        <li class="page-item">
                            <a class="page-link" href="/EntretienAnnuels/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=1">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left-short" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5" />
                                </svg>
                            </a>
                        </li>
                        @for (int i = 1; i <= ViewBag.NoOfPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.PageNo ? "active" : "")">
                                <a class="page-link" href="/EntretienAnnuels/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=@i">@i</a>
                            </li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="/EntretienAnnuels/Index?matricule=@ViewBag.Matricule&searchLetter=@Request.QueryString["searchLetter"]&PageNo=@ViewBag.NoOfPages"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-short" viewBox="0 0 16 16">
    <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8" />
</svg></a>
                        </li>

                    </ul>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col text-center">
            <p>Aucun entretien</p>
        </div>
    </div>
}


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // JavaScript code to handle delete button click
    document.addEventListener('DOMContentLoaded', function () {
        // Select all delete buttons
        var deleteButtons = document.querySelectorAll('.delete-btn');

        // Add click event listener to each delete button
        deleteButtons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                // Show SweetAlert2 confirmation modal
                Swal.fire({
                    title: 'Êtes-vous sûr de vouloir supprimer cet entretien ?',
                    text: 'Cette action est irréversible.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Oui, supprimer',
                    cancelButtonText: 'Annuler'
                }).then((result) => {
                    if (result.isConfirmed) {
                        var form = document.getElementById('deleteForm-' + btn.getAttribute('data-id'));
                        // Envoyer la requête de suppression via AJAX
                        $.ajax({
                            type: 'POST',
                            url: form.action,
                            data: $(form).serialize(),
                            success: function (response) {
                                // Afficher une SweetAlert pour indiquer le succès de la suppression
                                Swal.fire(
                                    'Supprimé!',
                                    'L\'entretien a été supprimé.',
                                    'success'
                                ).then(() => {
                                    // Actualiser la page ou effectuer d'autres actions si nécessaire
                                    location.reload();
                                });
                            },
                            error: function (xhr, status, error) {
                                // Afficher une SweetAlert pour indiquer une erreur lors de la suppression
                                Swal.fire(
                                    'Erreur!',
                                    'Une erreur s\'est produite lors de la suppression de l\'entretien.',
                                    'error'
                                );
                            }
                        });
                    }
                });
            });
        });
    });
</script>
