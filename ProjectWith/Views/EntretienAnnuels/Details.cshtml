<div class="modal fade" id="myModal2">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title">Ajouter un EvaluatinGenN_ </h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>

            <div class="modal-body">
                @using (Html.BeginForm("Create", "EvaluatinGenN_1", FormMethod.Post, new { id = "EvalGenForm" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="modal-body">
                        <div class="form-group">
                            <input type="hidden" name="idEntretien" value="@Model.entretienAnnuels.id" />
                            <label for="performance">Performance :</label>
                            @Html.DropDownListFor(model => model.entretienAnnuels.EvaluatinGenN_1.First().performance,
                                new SelectList(new List<SelectListItem>
                                {
                                    new SelectListItem { Text = "A:Supérieur aux attentes", Value = "A:Supérieur aux attentes" },
                                    new SelectListItem { Text = "B:Conforme aux attentes", Value = "B:Conforme aux attentes" },
                                    new SelectListItem { Text = "C:Inférieur aux attentes (plan d'action requis)", Value = "C:Inférieur aux attentes (plan d'action requis)" }
                                }, "Value", "Text"),
                                new { @class = "default-select form-control form-control-lg wide mb-3", Name = "performance" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label card-title">Commentaires</label>
                            <input type="text" name="commentaire" class="form-control" id="commentaire" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label card-title">Tendance</label>
                            <input type="text" name="tendance" class="form-control" id="tendance" />
                        </div>

                        <button type="submit" id="ajouterEVGen" class="btn btn-primary" style="width: 100px;">Ajouter</button>
                    </div>
                }


            </div>


        </div>
    </div>
</div>


