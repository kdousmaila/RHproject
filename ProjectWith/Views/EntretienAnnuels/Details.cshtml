                                <div id="tableContainer">
                                    <table id="objSpecifiqueTable">
                                        <tr>
                                            <td>Objectif Specifique</td>
                                            <td>Synthèse</td>
                                            <td>Action</td>
                                        </tr>
                                        @foreach (var objSpecifique in Model.entretienAnnuels.ObjSpecifique)
