<script>
    var currentStep = 1;
    var stepsNum = 5;

    // Show default page
    document.getElementById("stepPage" + currentStep).style.display = "block";
    document.getElementById("stepLable" + currentStep).classList.add("activeStep");

    function changeStep(active, newActive) {
        document.getElementById("stepPage" + active).style.display = "none";
        document.getElementById("stepPage" + newActive).style.display = "block";

        var activeStepLabel = document.querySelector(".activeStep");
        activeStepLabel.classList.remove("activeStep");
        var newActiveStepLabel = document.getElementById("stepLable" + newActive);
        newActiveStepLabel.classList.add("activeStep");

        var progress = (100 / (stepsNum - 1)) * (newActive - 1);
        document.getElementById("completedProgress").style.width = progress + "%";

        if (active < newActive) {
            activeStepLabel.classList.add("completedStep");
            activeStepLabel.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" style="font-size:40px" fill="currentColor" class="bi bi-check" viewBox="0 0 16 16">' +
                '<path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/>' +
                '</svg>';
        }

        if (newActiveStepLabel.classList.contains("completedStep")) {
            newActiveStepLabel.classList.remove("completedStep");
            newActiveStepLabel.innerHTML = newActive;
        }

        if (newActive === stepsNum) {
            document.getElementById("next").style.display = "none";
            var submitButton = document.getElementById("send");
            if (!submitButton) {
                submitButton = document.createElement("button");
                submitButton.innerHTML = "Submit";
                submitButton.type = "submit";
                submitButton.id = "send";
                submitButton.classList.add("btn", "btn-primary", "ml-2");
                submitButton.classList.add("fullWidth"); // Ajouter une classe pour augmenter la largeur du bouton

                submitButton.onclick = function (event) {
                    event.preventDefault();
                    handleFormSubmission();
                };
                document.getElementById("navigation").appendChild(submitButton);
            }
            hideSubmitButtonIfNecessary();
        } else {
            document.getElementById("next").style.display = "inline";
            var submitButton = document.getElementById("send");
            if (submitButton) {
                submitButton.parentNode.removeChild(submitButton);
            }
        }
    }

    document.querySelectorAll("#progressbarContainer ul li").forEach(function (stepLabel) {
        stepLabel.addEventListener("click", function () {
            var newStep = parseInt(stepLabel.innerHTML);
            if (newStep !== currentStep) {
                changeStep(currentStep, newStep);
                currentStep = newStep;
                document.getElementById("prev").style.visibility = currentStep === 1 ? "hidden" : "visible";
                document.getElementById("next").style.display = currentStep === stepsNum ? "none" : "inline";
            }
        });
    });

    document.getElementById("next").addEventListener("click", next);
    document.getElementById("prev").addEventListener("click", prev);

    function next(event) {
        event.preventDefault();
        window.scrollTo(0, 0);

        if (currentStep >= stepsNum) {
            handleFormSubmission();
        } else {
            changeStep(currentStep, currentStep + 1);
            currentStep++;
            document.getElementById("prev").style.visibility = "visible";

            if (currentStep === stepsNum) {
                document.getElementById("next").style.display = "none";
                var submitButton = document.getElementById("send");
                if (!submitButton) {
                    submitButton = document.createElement("button");
                    submitButton.innerHTML = "Submit";
                    submitButton.type = "submit";
                    submitButton.id = "send";
                    submitButton.classList.add("btn", "btn-primary", "ml-2");
                    submitButton.onclick = function (event) {
                        event.preventDefault();
                        handleFormSubmission();
                    };
                    document.getElementById("navigation").appendChild(submitButton);
                }
                hideSubmitButtonIfNecessary();
            } else {
                document.getElementById("next").innerHTML = "&gt;";
                document.getElementById("next").id = "next";
            }
        }
    }

    function prev(event) {
        event.preventDefault();
        window.scrollTo(0, 0);

        if (currentStep >= 2) {
            changeStep(currentStep, currentStep - 1);
            currentStep--;
            document.getElementById("prev").style.visibility = currentStep < 2 ? "hidden" : "visible";

            if (currentStep === stepsNum) {
                var submitButton = document.getElementById("send");
                if (submitButton) {
                    submitButton.parentNode.removeChild(submitButton);
                }
                document.getElementById("next").style.display = "inline";
            }
        }

        if (currentStep !== stepsNum) {
            var submitButton = document.getElementById("send");
            if (submitButton) {
                submitButton.parentNode.removeChild(submitButton);
            }
            document.getElementById("next").style.display = "inline";
        }
    }
    function handleFormSubmission() {
        var currentUserMatricule = document.getElementById("currentUserMatricule").value;
        var entretienMatricule = document.getElementById("Matricule").value;
        var employee = document.getElementById("res").value;

        console.log("currentUserMatricule:", currentUserMatricule);
        console.log("entretienMatricule:", entretienMatricule);
        console.log("employee:", employee);
        if (currentUserMatricule === entretienMatricule) {
            Swal.fire({
                title: 'Voulez-vous envoyer l\'entretien?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Oui',
                cancelButtonText: 'Non',
                cancelButtonColor: '#ff0000',
                customClass: {
                    confirmButton: 'swal2-button-size',
                    cancelButton: 'swal2-button-size'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById("status2").value = "envoyé";
                    document.getElementById("entretienForm").submit();
                }
            });
        } else {
            if (employee === currentUserMatricule) {
                Swal.fire({
                    title: 'Envoyer cette note ?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Oui',
                    cancelButtonText: 'Non',
                    cancelButtonColor: '#ff0000',
                    customClass: {
                        confirmButton: 'swal2-button-size',
                        cancelButton: 'swal2-button-size'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        var noteInput = document.getElementById("AAAAAAAA").value.trim();
                        console.log("Note input value:", noteInput);
                        var note = parseInt(noteInput);
                        console.log("Parsed note value:", note);
                        if (noteInput === '' || isNaN(note)) {
                            Swal.fire('Erreur', 'vous devez remplir le champs de note.', 'error');
                            return;
                        }
                        if (note < 0 || note > 20) {
                            Swal.fire('Erreur', 'La note doit être un entier entre 0 et 20', 'error');
                            return;
                        }
                        document.getElementById("status3").value = "fini";
                        document.getElementById("entretienForm").submit();
                    }
                });
            } else {
                Swal.fire({
                    title: 'Voulez-vous vraiment modifier cette note ?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Oui',
                    cancelButtonText: 'Non',
                    cancelButtonColor: '#ff0000',
                    customClass: {
                        confirmButton: 'swal2-button-size',
                        cancelButton: 'swal2-button-size'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById("entretienForm").submit();
                    }
                });

            }
        }
    }




    function hideSubmitButtonIfNecessary() {
        var status2 = document.getElementById("status2").value;
        var status3 = document.getElementById("status3").value; // Make sure status3 is correctly defined
        var currentUserMatricule = document.getElementById("currentUserMatricule").value;
        var entretienMatricule = document.getElementById("Matricule").value;
        var employee = document.getElementById("res").value;
        var role = document.getElementById("role").value;
      

        if (status2 === "envoyé" && currentUserMatricule === entretienMatricule) {
            var submitButton = document.getElementById("send");
            if (submitButton) {
                submitButton.style.display = "none";
            }
        }

        if (status3 === "fini" && (currentUserMatricule === employee)) {
            var submitButton = document.getElementById("send");
            if (submitButton) {
                submitButton.style.display = "none";
            }
        }

        if (status3 === "fini" && (role === "RH")) {
            var submitButton = document.getElementById("send");
            if (submitButton) {
                submitButton.style.display = "none";
            }
        }

       





    }

    // Initial check to hide the submit button if necessary when the page loads
    hideSubmitButtonIfNecessary();
</script>





