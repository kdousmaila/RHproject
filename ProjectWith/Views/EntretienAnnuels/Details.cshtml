                                        }
                                    </table>

                                </div>
                                <script>
    $(document).ready(function () {
        $('#objSpecifiqueTable').on('click', '.delete-link', function (e) {
            e.preventDefault();
            var id = $(this).data('id');

            // Utiliser SweetAlert pour la confirmation
            Swal.fire({
                title: 'Êtes-vous sûr?',
                text: 'Vous ne pourrez pas revenir en arrière!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Oui, supprimez-le!',
                cancelButtonText: 'Annuler',
                customClass: {
                    confirmButton: 'btn-large', // Apply custom class for larger button
                    cancelButton: 'btn-large'   // Apply custom class for larger button
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    deleteItem(id);
                }
            });
        });

        function deleteItem(id) {
            $.ajax({
                url: '@Url.Action("DeleteConfirmed", "ObjSpecifiques")',
                type: 'POST',
                data: {
                    id: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (result) {
                    $('a[data-id="' + id + '"]').closest('tr').remove();
                    Swal.fire(
                        'Supprimé!',
                        'Votre élément a été supprimé.',
                        'success'
                    );
                },
                error: function (xhr, status, error) {
                    Swal.fire(
                        'Erreur!',
                        'Une erreur s\'est produite lors de la tentative de suppression de l\'élément.',
                        'error'
                    );
                }
            });
        }
    });
                                </script>

