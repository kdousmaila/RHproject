<script>
    // Function to store the current step in session storage
    function setCurrentStep(step) {
        sessionStorage.setItem('currentStep', step);
    }

    // Function to retrieve the current step from session storage
    function getCurrentStep() {
        return sessionStorage.getItem('currentStep');
    }

    // Function to initialize the current step on page load
    window.onload = function () {
        var currentStep = getCurrentStep();
        if (currentStep) {
            // If a current step is stored, show that step
            showStep(currentStep);
        }
    }

    // Function to show the specified step
    function showStep(step) {
        // Hide all steps
        var steps = document.querySelectorAll('.stepPage');
        steps.forEach(function (step) {
            step.style.display = 'none';
        });

        // Show the specified step
        document.getElementById('stepPage' + step).style.display = 'block';

        // Store the current step
        setCurrentStep(step);
    }
</script>



<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Sélectionnez toutes les étapes
        var steps = document.querySelectorAll('.page-titles ul li');
        // Ajoutez un écouteur de clic à chaque étape
        steps.forEach(function (step, index) {
            step.addEventListener('click', function () {
                // Masquez toutes les parties du formulaire
                var allStepPages = document.querySelectorAll('.stepPage');
                allStepPages.forEach(function (page) {
                    page.style.display = 'none';
                });
                // Affichez uniquement la partie du formulaire correspondant à l'étape cliquée
                var selectedStepPage = document.getElementById('stepPage' + (index + 1));
                if (selectedStepPage) {
                    selectedStepPage.style.display = 'block';
                }
            });
        });
    });
</script>




