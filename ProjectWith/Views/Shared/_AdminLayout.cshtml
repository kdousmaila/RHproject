            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>
            <!-- Assurez-vous d'inclure SweetAlert -->

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>
            <!-- Assurez-vous d'inclure SweetAlert -->
            <script>
    document.addEventListener('DOMContentLoaded', function () {
        var openSessionLink = document.getElementById('openSessionLink');
        var closeSessionLink = document.getElementById('closeSessionLink');

        if (openSessionLink) {
            openSessionLink.addEventListener('click', function (event) {
                event.preventDefault(); // Empêche le comportement de lien par défaut
                // Utiliser SweetAlert pour confirmer l'ouverture de session
                Swal.fire({
                    title: 'Êtes-vous sûr?',
                    text: "Vous allez ouvrir la session.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Oui, ouvrez-la!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Si l'utilisateur confirme, effectuez l'action
                        $.ajax({
                            type: 'GET',
                            url: '@Url.Action("GrantAccess", "EntretienAnnuels")',
                            success: function (response) {
                                // Gérer la réponse en cas de succès
                                Swal.fire(
                                    'Session ouverte!',
                                    'La session a été ouverte.',
                                    'success'
                                ).then(() => {
                                    // Actualiser la page ou effectuer d'autres actions si nécessaire
                                    location.reload();
                                });
                            },
                            error: function (xhr, status, error) {
                                // Gérer les erreurs
                                Swal.fire(
                                    'Erreur!',
                                    'Une erreur s\'est produite lors de l\'ouverture de la session.',
                                    'error'
                                );
                            }
                        });
                    }
                });
            });
        }

        if (closeSessionLink) {
            closeSessionLink.addEventListener('click', function (event) {
                event.preventDefault(); // Empêche le comportement de lien par défaut
                // Utiliser SweetAlert pour confirmer la fermeture de session
                Swal.fire({
                    title: 'Êtes-vous sûr?',
                    text: "Vous allez fermer la session.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Oui, fermez-la!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Si l'utilisateur confirme, effectuez l'action
                        $.ajax({
                            type: 'GET',
                            url: '@Url.Action("RevokeAccess", "EntretienAnnuels")',
                            success: function (response) {
                                // Gérer la réponse en cas de succès
                                Swal.fire(
                                    'Session fermée!',
                                    'La session a été fermée.',
                                    'success'
                                ).then(() => {
                                    // Actualiser la page ou effectuer d'autres actions si nécessaire
                                    location.reload();
                                });
                            },
                            error: function (xhr, status, error) {
                                // Gérer les erreurs
                                Swal.fire(
                                    'Erreur!',
                                    'Une erreur s\'est produite lors de la fermeture de la session.',
                                    'error'
                                );
                            }
                        });
                    }
                });
            });
        }

        // Afficher l'alerte de session ouverte après avoir cliqué sur le lien

    });
            </script>



