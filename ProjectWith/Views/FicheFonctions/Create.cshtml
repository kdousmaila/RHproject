<script>
    $(document).ready(function () {
        var matriculeInput = $('#MatriculeInput');
        var matriculeErrorMessage = $('#matriculeErrorMessage2');
        var form = $('form');

        // Fonction pour valider la longueur du matricule
        function validateMatriculeLength() {
            var matricule = matriculeInput.val().trim();
            if (matricule.length !== 6) {
                showMatriculeLengthError("Le matricule doit comporter exactement 6 chiffres.");
                return false;
            }
            removeMatriculeLengthError();
            return true;
        }

        // Fonction pour afficher l'erreur de longueur de matricule
        function showMatriculeLengthError(message) {
            removeMatriculeLengthError();
            matriculeErrorMessage.text("Le matricule doit comporter exactement 6 chiffres.").show();
            matriculeInput.addClass('is-invalid');
        }

        // Fonction pour supprimer l'erreur de longueur de matricule
        function removeMatriculeLengthError() {
            matriculeErrorMessage.hide();
            matriculeInput.removeClass('is-invalid');
        }

        // Valider la longueur du matricule lors de la soumission du formulaire
        form.submit(function (event) {
            if (!validateMatriculeLength()) {
                event.preventDefault(); // Annuler la soumission du formulaire si la validation échoue
            }
        });

        // Valider la longueur du matricule lors de la perte de focus et au moment de la saisie
        matriculeInput.on('input blur', function () {
            validateMatriculeLength();
        });
    });


</script>
