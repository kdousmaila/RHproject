@model ProjectWith.Models.EmployeeFicheFonctionViewModel

@{
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>


    body {
        background-color: #eee;
    }

    .job-detail {
        border: 1px solid #ececec;
        border-radius: 6px;
        background-color: #fff;
    }

    .form-button .nice-select {
        width: 100%;
        height: 39px;
        line-height: 37px;
        color: #6b757d;
        margin-bottom: 1rem;
        border: solid 1px #e9e9e9;
    }

    .resume-user {
        position: relative;
        width: 100px;
        height: 100px;
        line-height: 100px;
        font-size: 66px;
        border-radius: 50px;
        top: 0;
        left: 0;
        right: 0;
        margin: 0 auto;
        background-color: #e9e9e9;
        color: #ff4f6c;
        -webkit-transition: all 0.5s;
        transition: all 0.5s;
        text-align: center;
    }

    .upload-btn-wide {
        width: 200px; /* Vous pouvez ajuster la largeur selon vos besoins */
    }

    .square-btn {
        width: 80px; /* Ajustez la largeur selon vos besoins */
        height: 50px; /* Ajustez la hauteur selon vos besoins */
        border: none;
        background-color: #c72727;
        color: #fff;
        font-size: 16px;
        border-radius: 10px; /* Utilisez le même rayon pour arrondir les coins */
        cursor: pointer;
        transition: background-color 0.3s; /* Transition sur la couleur de fond */
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .button-container {
        display: flex;
        justify-content: center; /* Centre le contenu horizontalement */
        margin-top: 20px; /* Ajoute de l'espace au-dessus du bouton */
    }
</style>




<link href="https://cdnjs.cloudflare.com/ajax/libs/MaterialDesign-Webfont/4.9.95/css/materialdesignicons.css" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/js/jquery.nice-select.min.js" integrity="sha256-Zr3vByTlMGQhvMfgkQ5BtWRSKBGa2QlspKYJnkjZTmo=" crossorigin="anonymous"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/css/nice-select.min.css" integrity="sha256-mLBIhmBvigTFWPSCtvdu6a76T+3Xyt+K571hupeFLg4=" crossorigin="anonymous" />
<div class="container">
    <div class="row">
        <div class="col-lg-12">
            <h3 class="text-dark">Informations générales</h3>
        </div>
    </div>


    @using (Html.BeginForm("Create", "FicheFonctions", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-lg-12">
                <div class="job-detail mt-2 p-4">
                    <div class="row justify-content-center">
                        <div class="card mb-4 mb-xl-0">
                            <div class="card-body text-center">
                                <img class="img-account-profile rounded-circle mb-2" id="profileImage" src="https://icon-library.com/images/no-profile-pic-icon/no-profile-pic-icon-11.jpg" alt="" style="width: 100px; height: 100px;">
                                <div class="small font-italic text-muted mb-4">JPG or PNG no larger than 5 MB</div>
                                <button class="btn" id="uploadBtn" type="button">Upload new image</button>
                                <input type="file" name="imageFile" id="imageFile" style="display: none;" />
                                <p id="fileUploadedText" style="display: none;">Image Uploaded</p>
                            </div>
                        </div>
                    </div>

                    <script>
                        var defaultImageSrc = document.getElementById('profileImage').src;

                        document.getElementById('uploadBtn').addEventListener('click', function () {
                            document.getElementById('imageFile').click();
                        });

                        document.getElementById('imageFile').addEventListener('change', function () {
                            var fileInput = this;
                            if (fileInput.files && fileInput.files[0]) {
                                var fileName = fileInput.files[0].name;
                                var fileType = fileName.split('.').pop().toLowerCase();

                                /*Vérifier si le type de fichier est JPEG ou PNG*/
                                if (fileType === 'jpg' || fileType === 'jpeg' || fileType === 'png') {
                                    var reader = new FileReader();

                                    reader.onload = function (e) {
                                        document.getElementById('profileImage').src = e.target.result;
                                        document.getElementById('fileUploadedText').style.display = 'block';
                                    }

                                    reader.readAsDataURL(fileInput.files[0]);
                                } else {
                                    alert('Veuillez choisir une image au format JPG ou PNG.');
                                    fileInput.value = ''; // Réinitialiser la valeur de l'entrée de fichier pour effacer la sélection invalide
                                    document.getElementById('profileImage').src = defaultImageSrc; // Réaffecter l'URL de l'image par défaut
                                }
                            }
                        });
                    </script>

                    <div class="custom-form" style="margin-top: 40px;">

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group app-label">
                                    <label for="Matricule">Matricule:</label>
                                    @Html.TextBoxFor(model => model.Employee.Matricule, new { @class = "form-control", @id = "MatriculeInput", type = "number" })

                                    <p id="matriculeErrorMessage2" style="color: red; display: none;">Matricule already exists. Please choose a different one.</p>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group app-label">
                                    <label for="frist-name" class="text-muted">Nom</label>
                                    @Html.TextBoxFor(model => model.FicheFonction.nom, new { @class = "form-control" })

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group app-label">
                                    <label for="middle-name" class="text-muted">Prenom</label>
                                    @Html.TextBoxFor(model => model.FicheFonction.prenom, new { @class = "form-control" })

                                </div>
                            </div>


                            <div class="col-md-4">
                                <div class="form-group app-label">
                                    <label for="General" class="text-muted">Numéro CIN</label>
                                    @Html.TextBoxFor(model => model.FicheFonction.numCin, new { @class = "form-control", type = "number", @id = "FicheFonction_numCin" })
                                    <p id="numCinErrorMessage" style="color: red; display: none;">La date de recrutement ne peut pas être dans le futur.</p>


                                </div>
                            </div>





                            <div class="col-md-4">
                                <div class="form-group app-label">
                                    <label for="date-of-birth" class="text-muted">Date de Naissance</label>
                                    @Html.EditorFor(model => model.FicheFonction.dateNaissance, new { htmlAttributes = new { @class = "form-control", @id = "dateNaissanceInput", type = "date" } })
                                    @Html.ValidationMessageFor(model => model.FicheFonction.dateNaissance, "", new { @class = "text-danger" })

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group app-label">

                                    <label for="citys" class="text-muted">Ville</label>
                                    <div class="form-button">
                                        @Html.EditorFor(model => model.FicheFonction.ville, new { htmlAttributes = new { @class = "form-control" } })
                                        @Html.ValidationMessageFor(model => model.FicheFonction.ville, "", new { @class = "text-danger" })

                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group app-label">
                                    <label for="country" class="text-muted">Poste</label>
                                    <div class="form-button">
                                        @Html.TextBoxFor(model => model.Employee.fonction, new { @class = "form-control", id = "fonctionInput" })
                                        @Html.ValidationMessageFor(model => model.Employee.fonction, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>






                            <div class="col-md-4">
                                <div class="form-group app-label">
                                    <label for="dateRecrutementInput" class="text-muted">Date de Recrutement</label>
                                    @Html.EditorFor(model => model.FicheFonction.dateRecrutement, new { htmlAttributes = new { @class = "form-control", @id = "dateRecrutementInput", type = "date" } })


                                    <p id="dateValidationMessage" style="color: red; display: none;"></p>

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group app-label">
                                    <label for="marital-status" class="text-muted">Etat Civil</label>
                                    <div class="form-button">
                                        @Html.DropDownListFor(model => model.FicheFonction.etatCivil,
      new SelectList(new[]
      {
                                         new SelectListItem { Text = "Célibataire", Value = "Célibataire" },
                                         new SelectListItem { Text = "Marié(e)", Value = "Marié(e)" },
                                         new SelectListItem { Text = "Divorcé(e)", Value = "Divorcé(e)" },
                                         new SelectListItem { Text = "Veuf/Veuve", Value = "Veuf/Veuve" }
      }, "Value", "Text"),

      new { @class = "form-control" })
                                        @Html.ValidationMessageFor(model => model.FicheFonction.etatCivil, "", new { @class = "text-danger" })

                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <h3 class="text-dark mt-5">Autres</h3>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="job-detail mt-2 p-4">
                    <div class="custom-form">
                        <form>
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group app-label">
                                        <label for="phone" class="text-muted">Numero de Telephone</label>
                                        @Html.EditorFor(model => model.FicheFonction.numero, new { htmlAttributes = new { @class = "form-control", @id = "telephoneInput" } })
                                        @Html.ValidationMessageFor(model => model.FicheFonction.numero, "", new { @class = "text-danger" })
                                        <span id="validationMessageTel" class="text-danger"></span>
                                    </div>
                                </div>


                                <div class="col-md-4">
                                    <div class="form-group app-label">
                                        <label for="e-mail" class="text-muted">E-mail</label>
                                        @Html.TextBoxFor(model => model.FicheFonction.email, new { @class = "form-control", type = "email", required = "required", id = "EmailInput" })
                                        @Html.ValidationMessageFor(model => model.FicheFonction.email, "", new { @class = "text-danger" })
                                        <p id="EmailErrorMessage2" style="color: red; display: none;">Email already exists. Please choose a different one.</p>
                                    </div>
                                </div>


                                <div class="col-md-4">
                                    <div class="form-group app-label">
                                        <label for="state" class="text-muted">Compte Windows</label>
                                        @Html.TextBoxFor(model => model.FicheFonction.cmptWindows, new { @class = "form-control", id = "CmptWinInput" })
                                        <p id="cmptWinErrorMessage" style="color: red; display: none;">Compte Windows déjà existant. Veuillez en choisir un autre.</p>
                                    </div>
                                </div>




                                <div class="col-md-4">
                                    <div class="form-group app-label">
                                        <label for="marital-status" class="text-muted">Responsable hierarchique</label>
                                        <div class="form-button">
                                            @Html.DropDownListFor(model => model.SelectedEmployeeChef, (SelectList)ViewBag.EmployeesWithRoleChef, "Select an employee", new { @class = "form-control" })
                                        </div>

                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="form-group app-label">
                                        <div class="form-button">
                                            <label for="state" class="text-muted">Departement</label>

                                            @Html.DropDownListFor(model => model.FicheFonction.idDepartement, new SelectList(Model.Departements, "id", "nomDepartement"), htmlAttributes: new { @class = "form-control" })

                                            @Html.ValidationMessageFor(model => model.FicheFonction.idDepartement, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                                @Html.HiddenFor(model => model.Employee.Service)


                                <div class="col-md-4">
                                    <div class="form-group app-label">
                                        <label for="marital-status" class="text-muted">Responsable Fonctionnel</label>
                                        <div class="form-button">
                                            @Html.TextBoxFor(model => model.EmployeeDS, new { @class = "form-control", @readonly = "readonly" })
                                        </div>
                                    </div>
                                </div>




                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>







        <div class="button-container">
            <div class="square-btn" id="submitBtn">Submit</div>
        </div>




    }

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>


