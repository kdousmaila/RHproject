<script>
    $(document).ready(function () {
        var dateRecrutementInput = $('#dateRecrutementInput');
        var dateValidationMessage = $('#dateValidationMessage');
        var submitBtn = $('#submitBtn');

        function validateDate() {
            var inputDate = dateRecrutementInput.val();
            var selectedDate = new Date(inputDate);
            var today = new Date();
            var minDate = new Date("2012-06-15");

            if (selectedDate > today) {
                // Display error message for future date

                dateValidationMessage.text('La date de recrutement ne peut pas être dans le futur.').show();
                submitBtn.prop('disabled', true);
                return false;
            } else if (selectedDate < minDate) {
                // Display error message for date before 15 June 2012
                dateValidationMessage.text('La date de recrutement ne peut pas être antérieure au 15 juin 2012.').show();
                submitBtn.prop('disabled', true);
                return false;
            }

            // Clear any previous error message
            dateValidationMessage.text('');
            submitBtn.prop('disabled', false);
            return true;
        }

        dateRecrutementInput.on('blur', validateDate);

        $('form').on('submit', function (event) {
            if (!validateDate()) {
                event.preventDefault(); // Prevent form submission if date is not valid
            }
        });
    });
</script>

