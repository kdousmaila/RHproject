<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>




@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>





<script>
    $(document).ready(function () {
        var matriculeInput = $('#MatriculeInput');
        var telephoneInput = $('#telephoneInput');
        var dateNaissanceInput = $('#dateNaissanceInput');
        var matriculeErrorMessage2 = $('#matriculeErrorMessage2');

        function validateCIN() {
            var cinRegex = /^(0|1)\d{7}$/;
            var cinNumber = $('#FicheFonction_numCin').val().trim();
            if (cinNumber !== '' && !cinRegex.test(cinNumber)) {
                showCINError("Veuillez saisir un numéro CIN tunisien valide.");
                return false;
            }
            removeCINError();
            return true;
        }

        // Function to show CIN error
        function showCINError(message) {
            removeCINError();
            var errorMessage = $('<div class="text-danger cin-error">' + message + '</div>');
            $('#FicheFonction_numCin').parent().append(errorMessage);
            $('#FicheFonction_numCin').addClass('is-invalid');
        }

        // Function to remove CIN error
        function removeCINError() {
            $('#FicheFonction_numCin').parent().find('.cin-error').remove();
            $('#FicheFonction_numCin').removeClass('is-invalid');
        }

        // Bind blur event to CIN input field
        $('#FicheFonction_numCin').blur(function () {
            validateCIN();
        });


        function validateMatriculeEmail() {
            return new Promise(function (resolve, reject) {
                var matricule = matriculeInput.val().trim();
                var email = $("input[name='FicheFonction.email']").val().trim();

                if (matricule === '' && email === '') {
                    matriculeInput.addClass('is-invalid');
                    $("input[name='FicheFonction.email']").addClass('is-invalid');
                    return reject();
                }

                if (email !== '') {
                    $.ajax({
                        url: '/FicheFonctions/CheckEmail',
                        type: 'GET',
                        data: { email: email },
                        success: function (result) {
                            if (result.exists) {
                                $("input[name='FicheFonction.email']").addClass('is-invalid');
                                $("input[name='FicheFonction.email']").siblings('.email-error').remove();
                                $("input[name='FicheFonction.email']").after('<div class="text-danger email-error">email existe déjà.Veuillez en utiliser un autre.</div>');
                                return reject();
                            } else {
                                $("input[name='FicheFonction.email']").removeClass('is-invalid');
                                $("input[name='FicheFonction.email']").siblings('.email-error').remove();
                                return resolve();
                            }
                        },
                        error: function () {
                            swal({
                                text: "Error checking email existence.",
                                icon: "error",
                                buttons: {
                                    confirm: {
                                        text: "OK",
                                        value: true,
                                        visible: true,
                                        className: "btn-primary",
                                        closeModal: true
                                    }
                                }
                            });
                            return reject();
                        }
                    });
                } else {
                    $("input[name='FicheFonction.email']").removeClass('is-invalid');
                    $("input[name='FicheFonction.email']").siblings('.email-error').remove();
                    return resolve();
                }
            });
        }

        function validateDateOfBirth() {
            var dateNaissance = dateNaissanceInput.val();
            if (dateNaissance) {
                var age = calculateAge(dateNaissance);
                if (age < 18) {
                    showDateNaissanceError("L'employé doit avoir au moins 18 ans.");
                    return false;
                } else {
                    removeDateNaissanceError();
                }
            }
            return true;
        }

        function showDateNaissanceError(message) {
            removeDateNaissanceError();
            var errorMessage = $('<div class="text-danger date-naissance-error">' + message + '</div>');
            dateNaissanceInput.parent().append(errorMessage);
            dateNaissanceInput.addClass('is-invalid');
        }

        function removeDateNaissanceError() {
            dateNaissanceInput.parent().find('.date-naissance-error').remove();
            dateNaissanceInput.removeClass('is-invalid');
        }

        function calculateAge(dateString) {
            var today = new Date();
            var birthDate = new Date(dateString);
            var age = today.getFullYear() - birthDate.getFullYear();
            var m = today.getMonth() - birthDate.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
                age--;
            }
            return age;
        }

        function validatePhoneNumber() {
            var phoneRegex = /^(?:\+?216)?(?:\s?\d{2}){4}$/;
            var phoneNumber = telephoneInput.val().trim();
            if (phoneNumber !== '' && !phoneRegex.test(phoneNumber)) {
                showPhoneNumberError("Veuillez saisir un numéro de téléphone tunisien valide.");
                return false;
            }
            removePhoneNumberError();
            return true;
        }

        function showPhoneNumberError(message) {
            removePhoneNumberError();
            var errorMessage = $('<div class="text-danger phone-number-error">' + message + '</div>');
            telephoneInput.parent().append(errorMessage);
            telephoneInput.addClass('is-invalid');
        }

        function removePhoneNumberError() {
            telephoneInput.parent().find('.phone-number-error').remove();
            telephoneInput.removeClass('is-invalid');
        }

        telephoneInput.blur(function () {
            var phoneNumber = telephoneInput.val().trim();
            if (phoneNumber !== '' && !validatePhoneNumber(phoneNumber)) {
                showPhoneNumberError("Veuillez saisir un numéro de téléphone tunisien valide..");
            } else {
                removePhoneNumberError();
            }
        });

        dateNaissanceInput.blur(function () {
            validateDateOfBirth();
        });

        function validateForm() {
            return new Promise(function (resolve, reject) {
                var isFormValid = true;

                $('input[type="text"], input[type="email"], input[type="date"], select').each(function () {
                    if (!$(this).val().trim() && !$(this).is(':disabled') && $(this).is(":visible")) {
                        swal({
                            text: "Please fill in all fields.",
                            icon: "error",
                            buttons: {
                                confirm: {
                                    text: "OK",
                                    value: true,
                                    visible: true,
                                    className: "btn-primary",
                                    closeModal: true
                                }
                            }
                        });
                        isFormValid = false;
                        return false;
                    }
                });

                if (!isFormValid) {
                    return reject();
                }

                validateMatriculeEmail().then(function () {
                    if (!validateDateOfBirth()) {
                        isFormValid = false;
                    }
                    if (!validateCIN()) {
                        isFormValid = false;
                    }
                    if (!validatePhoneNumber()) {
                        isFormValid = false;
                    }

                    if (isFormValid) {
                        resolve();
                    } else {
                        reject();
                    }
                }).catch(function () {
                    isFormValid = false;
                    reject();
                });
            });
        }

        var submitBtn = $('#submitBtn');

        matriculeInput.on('blur', function () {
            var matricule = $(this).val();
            if (matricule !== '') {
                $.ajax({
                    url: '/FicheFonctions/CheckMatricule',
                    type: 'GET',
                    data: { matricule: matricule },
                    success: function (result) {
                        if (result.exists) {
                            matriculeErrorMessage2.text('Le matricule existe déjà. Veuillez en choisir un autre').show();
                            submitBtn.prop('disabled', true);
                        } else {
                            matriculeErrorMessage2.hide();
                            submitBtn.prop('disabled', false);

                            $("#submitBtn").click(function (e) {
                                e.preventDefault();
                                validateForm().then(function () {
                                    $("form").submit();
                                }).catch(function () {
                                    // Handle form validation failure
                                });
                            });
                        }
                    }
                });
            }
        });

        // Event listener for email input blur
        $("input[name='FicheFonction.email']").blur(function () {
            var email = $(this).val().trim();
            if (email !== '') {
                $.ajax({
                    url: '/FicheFonctions/CheckEmail',
                    type: 'GET',
                    data: { email: email },
                    success: function (result) {
                        if (result.exists) {
                            // Email already exists, show error message
                            $("input[name='FicheFonction.email']").addClass('is-invalid');
                            $("input[name='FicheFonction.email']").siblings('.email-error').remove(); // Remove previous error message if any
                            $("input[name='FicheFonction.email']").after('<div class="text-danger email-error">email existe déjà.Veuillez en utiliser un autre.</div>');
                        } else {
                            // Email doesn't exist, remove any existing error message
                            $("input[name='FicheFonction.email']").removeClass('is-invalid');
                            $("input[name='FicheFonction.email']").siblings('.email-error').remove();
                        }
                    },
                    error: function () {
                        // Error occurred, reject the promise
                        swal({
                            text: "Error checking email existence.",
                            icon: "error",
                            buttons: {
                                confirm: {
                                    text: "OK",
                                    value: true,
                                    visible: true,
                                    className: "btn-primary",
                                    closeModal: true
                                }
                            }
                        });
                    }
                });
            } else {
                // If email is empty, remove any existing error message
                $("input[name='FicheFonction.email']").removeClass('is-invalid');
                $("input[name='FicheFonction.email']").siblings('.email-error').remove();
            }
        });
    });

</script>
<script>
    $(document).ready(function () {
        var cmptWinInput = $('#CmptWinInput');
        var cmptWinErrorMessage = $('#cmptWinErrorMessage');
        var cmptWinExists = false;
        var submitBtn = $('#submitBtn'); // Reference to the submit button

        // Vérifie l'existence du compte Windows à chaque frappe de touche
        cmptWinInput.on('keyup', function () {
            var cmptWin = cmptWinInput.val();
            $.ajax({
                url: '/FicheFonctions/CheckWin', // Assurez-vous que l'URL correspond à votre route réelle
                type: 'GET',
                data: { win: cmptWin },
                success: function (result) {
                    if (result.exists) {
                        // Affiche un message d'erreur si le compte Windows existe déjà
                        cmptWinErrorMessage.text('Compte Windows déjà existant. Veuillez en choisir un autre.').show();
                        cmptWinExists = true;
                        submitBtn.prop('disabled', true); // Disable the submit button
                    } else {
                        // Cache le message d'erreur si le compte Windows est unique
                        cmptWinErrorMessage.hide();
                        cmptWinExists = false;
                        submitBtn.prop('disabled', false); // Enable the submit button
                    }
                }
            });
        });

        // Empêche la soumission du formulaire si le compte Windows existe déjà
        $('form').on('submit', function (event) {
            if (cmptWinExists) {
                event.preventDefault(); // Empêche le formulaire de se soumettre
                //submitBtn.prop('disabled', true); // Ensure submit button is disabled
            }
        });
    });

</script>
