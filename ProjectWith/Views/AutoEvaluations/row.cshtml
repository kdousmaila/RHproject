
@model ProjectWith.Models.AutoEvaluation

<style>
    .swal2-cancel {
        width: 100px;
    }
</style>


<li>
    <span>@Model.theme </span>
    <span>@Model.lieu</span>
    <span>@Model.duree</span>
    <span>
        @Html.ActionLink("Delete", "Delete", "AutoEvaluations", new { id = Model.id }, new { @class = "delete-link", data_id = Model.id })

        @Html.AntiForgeryToken() <!-- Add anti-forgery token here -->

    </span>
</li>



<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script> <!-- Inclure SweetAlert -->

